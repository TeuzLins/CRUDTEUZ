{
  "name": "crudteuz-monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "scripts": {
    "setup": "npm --prefix server install && npm --prefix client install",
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "function-bind": "^1.1.2",
    "mime-db": "^1.54.0",
    "negotiator": "^1.0.0",
    "picomatch": "^4.0.3"
  }
}
